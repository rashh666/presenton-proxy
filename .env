# Proxy — GPU Manager settings
# These are read by presenton_proxy.py on the HOST.

# Absolute path to your local models folder
MODELS_HOST_PATH=/home/rashid/my-project/models

# Absolute path to the compiled native llama-server executable
LLAMA_SERVER_BIN=/home/rashid/llama.cpp/build/bin/llama-server

# Pool both RX 9060 XT GPUs (0 and 1) for a single massive model on port 8081
UNIFIED_SINGLE_MODEL=true

# Model key — must match a filename under MODELS_HOST_PATH/reasoner/
REASONER_MODEL_KEY=gemma3

# Idle seconds before the watchdog flushes VRAM (0 = never flush)
IDLE_TIMEOUT=600

# LLM inference timeout in seconds (Gemma 27B can take 3-5 min on first token)
LLM_TIMEOUT=600

# Optional: protect the proxy with a Bearer token
# If set, Presenton's CUSTOM_LLM_API_KEY (PROXY_API_KEY in docker-compose) must match
# API_KEY=change-me

# ---- Presenton docker-compose (production-amd profile) reads these ----
# Image provider: disabled | pexels | pixabay | comfyui
IMAGE_PROVIDER=disabled
# COMFYUI_URL=http://localhost:8188
# PEXELS_API_KEY=
# PIXABAY_API_KEY=
